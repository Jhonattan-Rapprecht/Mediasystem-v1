# Uploaded media files (can be large and are user-generated)
app-media/images/*
app-media/videos/*
app-media/music/*
app-media/documents/*

# Keep the folders themselves
!app-media/images/.gitkeep
!app-media/videos/.gitkeep
!app-media/music/.gitkeep
!app-media/documents/.gitkeep

